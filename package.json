{
  "name": "command-sound",
  "displayName": "command-sound",
  "publisher": "aleksandar-stefanovic",
  "description": "A VS Code extension that plays a sound after a successful/unsuccessful command.",
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["*"],
  "main": "./extension.js",
  "contributes": {
    "commands": [],
    "configuration": {
      "title": "Command Sound",
      "properties": {
        "commandSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable sound playback when terminal commands complete."
        },
        "commandSound.timeout": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum time in seconds to play the sound before stopping it."
        },
        "commandSound.minInterval": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 10,
          "description": "Minimum time in seconds between playing sounds."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
